			wallpaperCount += 6;
			console.log(`加载 ${wallpaperCount} 张壁纸`);
			this.textContent = '加载更多壁纸...';
			setTimeout(() => {
				this.textContent = '加载更多壁纸';
			}, 1000);
		});

		// ========== 灯箱功能 ==========
		const lightbox = document.getElementById('lightbox') as HTMLDivElement | null;
		const lightboxImage = document.getElementById('lightboxImage') as HTMLImageElement | null;
		const lightboxCaption = document.getElementById('lightboxCaption') as HTMLDivElement | null;
		const lightboxClose = document.getElementById('lightboxClose') as HTMLButtonElement | null;
		const lightboxPrev = document.getElementById('lightboxPrev') as HTMLButtonElement | null;
		const lightboxNext = document.getElementById('lightboxNext') as HTMLButtonElement | null;

		let currentImages: Array<{ title: string; icon: string }> = [];
		let currentIndex = 0;

		function initLightbox() {
			if (!lightbox || !lightboxImage || !lightboxCaption || !lightboxClose || !lightboxPrev || !lightboxNext) {
				return;
			}

			// 壁纸点击
			document.querySelectorAll<HTMLElement>('.wallpaper-preview, .screenshot-preview, .concept-preview').forEach((el) => {
				el.style.cursor = 'pointer';
				el.addEventListener('click', function(this: HTMLElement, e: MouseEvent) {
					e.stopPropagation();
					const card = this.closest<HTMLElement>('.media-card');
					const title = card?.querySelector<HTMLElement>('.wallpaper-title, .screenshot-title, .concept-title')?.textContent || '媒体预览';
					const icon = this.querySelector<HTMLElement>('.wallpaper-icon, .screenshot-icon, .concept-icon')?.textContent || '🖼️';

					const parentGrid = this.closest<HTMLElement>('.media-grid');
					if (parentGrid) {
						const allPreviews = parentGrid.querySelectorAll<HTMLElement>('.wallpaper-preview, .screenshot-preview, .concept-preview');
						currentImages = Array.from(allPreviews).map((preview) => {
							const card = preview.closest<HTMLElement>('.media-card');
							const imgTitle = card?.querySelector<HTMLElement>('.wallpaper-title, .screenshot-title, .concept-title')?.textContent || '媒体预览';
							const imgIcon = preview.querySelector<HTMLElement>('.wallpaper-icon, .screenshot-icon, .concept-icon')?.textContent || '🖼️';
							return {
								title: imgTitle,
								icon: imgIcon
							};
						});
						currentIndex = Array.from(allPreviews).indexOf(this);
					} else {
						currentImages = [{ title, icon }];
						currentIndex = 0;
					}

					openLightbox(currentIndex);
				});
			});

			// 截图和概念艺术的卡片本身也可点击
			document.querySelectorAll<HTMLElement>('.screenshot-card, .concept-card').forEach((card) => {
				card.style.cursor = 'pointer';
				card.addEventListener('click', function(this: HTMLElement, e: MouseEvent) {
					if ((e.target as HTMLElement).closest('.btn-download, .music-play, a')) return;
					const preview = this.querySelector<HTMLElement>('.screenshot-preview, .concept-preview');
					if (preview) {
						preview.click();
					}
				});
			});
		}

		function openLightbox(index: number) {
			const item = currentImages[index];
			if (!item || !lightbox || !lightboxImage || !lightboxCaption) return;
	
			const canvas = document.createElement('canvas');
			canvas.width = 800;
			canvas.height = 450;
			const ctx = canvas.getContext('2d');
			if (!ctx) return;
	
			const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
			gradient.addColorStop(0, '#0a0a0a');
			gradient.addColorStop(0.5, '#1a1a1a');
			gradient.addColorStop(1, '#2a2a2a');
			ctx.fillStyle = gradient;
			ctx.fillRect(0, 0, canvas.width, canvas.height);
	
			ctx.font = '120px sans-serif';
			ctx.textAlign = 'center';
			ctx.textBaseline = 'middle';
			ctx.fillStyle = 'rgba(238, 229, 0, 0.15)';
			ctx.fillText(item.icon || '🖼️', canvas.width / 2, canvas.height / 2 - 20);
	
			ctx.font = '24px "Courier New", monospace';
			ctx.fillStyle = '#fcee0a';
			ctx.textAlign = 'center';
			ctx.textBaseline = 'bottom';
			ctx.fillText(item.title || '媒体预览', canvas.width / 2, canvas.height - 40);
	
			ctx.strokeStyle = 'rgba(238, 229, 0, 0.3)';
			ctx.lineWidth = 2;
			ctx.strokeRect(20, 20, canvas.width - 40, canvas.height - 40);
	
			lightboxImage.src = canvas.toDataURL('image/png');
			lightboxCaption.textContent = item.title || '媒体预览';
			lightbox.classList.add('active');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			if (!lightbox) return;
			lightbox.classList.remove('active');
			document.body.style.overflow = '';
		}

		function changeImage(direction: number) {
			if (currentImages.length === 0) return;
			currentIndex = (currentIndex + direction + currentImages.length) % currentImages.length;
			openLightbox(currentIndex);
		}

		if (lightboxClose && lightboxPrev && lightboxNext && lightbox) {
			lightboxClose.addEventListener('click', closeLightbox);
			lightboxPrev.addEventListener('click', (e) => { e.stopPropagation(); changeImage(-1); });
			lightboxNext.addEventListener('click', (e) => { e.stopPropagation(); changeImage(1); });

			lightbox.addEventListener('click', function(this: HTMLDivElement, e: MouseEvent) {
				if (e.target === this) closeLightbox();
			});
		}

		document.addEventListener('keydown', function(e: KeyboardEvent) {
			if (!lightbox || !lightbox.classList.contains('active')) return;
			if (e.key === 'Escape') closeLightbox();
			if (e.key === 'ArrowLeft') changeImage(-1);
			if (e.key === 'ArrowRight') changeImage(1);
		});

		document.addEventListener('DOMContentLoaded', initLightbox);
	</script>
</Layout>

