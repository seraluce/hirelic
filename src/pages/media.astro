				const song = this.dataset.song;
				console.log(`播放歌曲: ${song}`);
				this.innerHTML = '<span>⏸</span>';
			});
		});

		// Tab切换功能
		type MediaTabKey = 'music' | 'wallpaper' | 'screenshots' | 'concept';
		const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
		const sections: Record<MediaTabKey, HTMLElement | null> = {
			music: document.getElementById('music'),
			wallpaper: document.getElementById('wallpaper'),
			screenshots: document.getElementById('screenshots'),
			concept: document.getElementById('concept')
		};

		// 默认显示音乐
		(Object.keys(sections) as MediaTabKey[]).forEach((key) => {
			const section = sections[key];
			if (section && key !== 'music') {
				section.style.display = 'none';
			}
		});

		tabs.forEach((tab) => {
			tab.addEventListener('click', function(this: HTMLButtonElement) {
				tabs.forEach((t) => t.classList.remove('active'));
				this.classList.add('active');

				const tabId = this.dataset.tab as MediaTabKey | undefined;
				(Object.keys(sections) as MediaTabKey[]).forEach((key) => {
					const section = sections[key];
					if (!section) return;
					section.style.display = key === tabId ? 'block' : 'none';
				});
			});
		});

		// 加载更多壁纸
		let wallpaperCount = 0;
